---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/TableOfContents.astro';

const tocEntries = [
    { id: 'cdn',       label: 'Via CDN',   level: 1 as const },
    { id: 'npm',       label: 'Via npm',   level: 1 as const },
    { id: 'autoloader', label: 'Autoloader', level: 1 as const },
    { id: 'prerequis', label: 'Prérequis', level: 1 as const },
];

const codeCdn = `<!-- Composants (autoloader : ne charge que ce qui est utilisé) -->
<script type="module" src="https://unpkg.com/@ariane-ui/core/cdn/index.js"></scr` + `ipt>

<!-- Thème par défaut -->
<link rel="stylesheet" href="https://unpkg.com/@ariane-ui/core/themes/default.css" />`;

const codeCdnUsage = `<ar-alert version="success">
  <span slot="title">Succès</span>
  <span slot="content">Opération réussie.</span>
</ar-alert>`;

const codeNpmInstall = `npm install @ariane-ui/core`;

const codeNpmGlobal = `import '@ariane-ui/core';
import '@ariane-ui/core/themes/default.css';`;

const codeNpmIndividuel = `import '@ariane-ui/core/dist/components/alert/alert.js';
import '@ariane-ui/core/themes/default.css';`;

const codeAutoloader = `<script type="module" src="https://unpkg.com/@ariane-ui/core/cdn/autoloader.js"></scr` + `ipt>`;
---

<Layout
    title="Installation"
    currentPath="/getting-started/installation"
    showToc={true}
>
    <div class="page-container">
        <div class="page-header">
            <h2 class="page-title">Installation</h2>
        </div>
        <section id="cdn">
            <h3 class="section-title">Via CDN <span class="badge">Sans bundler</span></h3>
            <p>
                La méthode la plus rapide. Ajoutez les deux balises dans votre <code>&lt;head&gt;</code> —
                les composants s'enregistrent automatiquement.
            </p>
            <pre><code class="language-html" set:text={codeCdn} /></pre>
            <p>Les composants sont ensuite utilisables directement dans votre HTML :</p>
            <pre><code class="language-html" set:text={codeCdnUsage} /></pre>
        </section>
        <section id="npm" class="main-section">
            <div>
                <h3 class="section-title">Via NPM <span class="badge">Avec bundler</span></h3>
                <p>Pour une intégration dans un projet avec bundler (Vite, Webpack, Rollup…).</p>
                <pre><code class="language-bash" set:text={codeNpmInstall} /></pre>
            </div>
            <section class="subsection">
                <h4 class="subsection-title">Import global</h4>
                <p>Enregistre tous les composants en une seule ligne :</p>
                <pre><code class="language-typescript" set:text={codeNpmGlobal} /></pre>
            </section>
            <section class="subsection">
                <h4 class="subsection-title">Import individuel <span class="badge badge-subtle">Tree-shaking</span></h4>
                <p>Pour inclure uniquement les composants effectivement utilisés :</p>
                <pre><code class="language-typescript" set:text={codeNpmIndividuel} /></pre>
            </section>
        </section>
        <section id="autoloader">
            <h3 class="section-title">Autoloader CDN</h3>
            <p>
                Le bundle CDN inclut un autoloader qui ne charge chaque composant que quand il est utilisé
                dans la page :
            </p>
            <pre><code class="language-html" set:text={codeAutoloader} /></pre>
        </section>
        <section id="prerequis">
            <h3 class="section-title">Prérequis</h3>
            <ul>
                <li>Node ≥ 20</li>
                <li>npm ≥ 10</li>
                <li>
                    Un navigateur supportant les
                    <a href="https://developer.mozilla.org/en-US/docs/Web/API/Web_components" target="_blank" rel="noopener">
                        Web Components
                    </a>
                    (tous les navigateurs modernes)
                </li>
            </ul>
        </section>
    </div>

    <TableOfContents entries={tocEntries} slot="toc" />
</Layout>

<style>
    @import '../../styles/doc-prose.css';
</style>
