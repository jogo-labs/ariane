---
/**
 * TableOfContents.astro
 *
 * Desktop : sticky à droite dans la colonne TOC.
 * Mobile  : bloc <details>/<summary> collapsible injecté dans le flux de la page
 *           (la colonne toc-column est cachée en mobile via Layout.astro).
 */

interface TocEntry {
    id:    string;
    label: string;
    level: 1 | 2;
}

interface Props {
    entries:    TocEntry[];
    mobileOnly?: boolean;
}

const { entries, mobileOnly = false } = Astro.props;
---

<!-- Desktop : sticky dans la colonne de droite (masqué si mobileOnly) -->
<nav class={`toc toc-desktop${mobileOnly ? ' toc-hidden' : ''}`} aria-label="Sur cette page">
    <p class="toc-title">Sur cette page</p>
    <ul>
        {entries.map((entry) => (
            <li class={`toc-item level-${entry.level}`}>
                <a href={`#${entry.id}`} class="toc-link">{entry.label}</a>
            </li>
        ))}
    </ul>
</nav>

<!-- Mobile : collapse injecté dans le contenu principal (via slot="toc" → ignoré en mobile,
     donc on l'injecte aussi via un slot sans nom dans [slug].astro — voir ci-dessous) -->
<details class="toc-mobile">
    <summary>Sur cette page</summary>
    <ul>
        {entries.map((entry) => (
            <li class={`toc-item level-${entry.level}`}>
                <a href={`#${entry.id}`} class="toc-link-m">{entry.label}</a>
            </li>
        ))}
    </ul>
</details>

<script>
    // Un seul observer global — initialisé une seule fois même si le composant est monté deux fois
    if (!(window as any).__tocObserverInit) {
        (window as any).__tocObserverInit = true;

        const allLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
        if (allLinks.length > 0) {
            const ids = Array.from(allLinks)
                .map((l) => l.getAttribute('href')!.slice(1))
                .filter((v, i, a) => a.indexOf(v) === i); // dédupliquer

            const headings = ids
                .map((id) => document.getElementById(id))
                .filter(Boolean) as HTMLElement[];

            const observer = new IntersectionObserver(
                (entries) => {
                    for (const entry of entries) {
                        if (entry.isIntersecting) {
                            document.querySelectorAll<HTMLAnchorElement>('.toc-link').forEach((l) =>
                                l.classList.remove('active')
                            );
                            document
                                .querySelectorAll<HTMLAnchorElement>(`.toc-link[href="#${entry.target.id}"]`)
                                .forEach((l) => l.classList.add('active'));
                        }
                    }
                },
                { rootMargin: '-10% 0px -60% 0px', threshold: 0 },
            );

            headings.forEach((h) => observer.observe(h));
        }
    }

    // Fermer le details mobile après un clic sur un lien
    document.querySelectorAll<HTMLAnchorElement>('.toc-link-m').forEach((a) => {
        a.addEventListener('click', () => {
            const details = a.closest('details');
            if (details) details.open = false;
        });
    });
</script>

<style>
    /* ── Desktop ────────────────────────────────────────────── */

    .toc-hidden { display: none !important; }

    .toc-desktop {
        position:   sticky;
        top:        2rem;
        font-size:  0.8rem;
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
        padding:    0 0.5rem;
    }

    .toc-mobile { display: none; }

    .toc-title {
        font-size:      0.65rem;
        font-weight:    600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color:          #6b7280;
        margin:         0 0 0.5rem;
    }

    ul {
        list-style: none;
        margin:     0;
        padding:    0;
    }

    .toc-item        { margin: 0; }
    .toc-item.level-2 { padding-left: 1rem; }

    .toc-link,
    .toc-link-m {
        display:         block;
        padding:         0.25rem 0.5rem;
        padding-left:    0.75rem;
        color:           var(--doc-text-subtle, #4b5563);
        text-decoration: none;
        border-left:     2px solid transparent;
        line-height:     1.4;
        font-size:       0.78rem;
        transition:      color 0.1s, border-color 0.1s;
    }

    .toc-link:hover,
    .toc-link-m:hover {
        color:        var(--doc-text, #111827);
        border-color: var(--doc-border, #e5e7eb);
    }

    .toc-link.active {
        color:        var(--doc-accent, #7c3aed);
        border-color: var(--doc-accent, #7c3aed);
    }

    /* ── Mobile ─────────────────────────────────────────────── */

    @media (max-width: 768px) {
        .toc-desktop { display: none; }
        .toc-mobile  {
            display:       block;
            margin:        0 0 1.5rem;
            border:        1px solid var(--doc-border, #e5e7eb);
            border-radius: 0.5rem;
            background:    var(--doc-nav-bg, #f8f9fb);
            font-size:     0.875rem;
        }

        .toc-mobile summary {
            padding:         0.6rem 0.875rem;
            font-weight:     600;
            font-size:       0.8rem;
            text-transform:  uppercase;
            letter-spacing:  0.06em;
            color:           var(--doc-text-muted, #6b7280);
            cursor:          pointer;
            list-style:      none;
            display:         flex;
            align-items:     center;
            justify-content: space-between;
        }

        .toc-mobile summary::after {
            content:     '▾';
            font-size:   0.75rem;
            transition:  transform 0.15s;
        }

        .toc-mobile[open] summary::after {
            transform: rotate(180deg);
        }

        .toc-mobile ul {
            padding:       0 0.5rem 0.5rem;
            border-top:    1px solid var(--doc-border, #e5e7eb);
        }
    }
</style>
