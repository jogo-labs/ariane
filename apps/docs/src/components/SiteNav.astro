---
/**
 * SiteNav.astro
 *
 * Navigation principale du Design System.
 * Structure en sections : Foundations, Components.
 * Les composants sont auto-générés depuis le CEM + MDX.
 */
import { getCollection } from 'astro:content';
import { getSlug } from '../utils/tag-name.ts';
import manifest from '@cem';
import { version } from '../../../../packages/core/package.json';
import rootPkg from '../../../../package.json';
import { type CemDeclaration, getCustomElements } from '../utils/cem-types.ts';

interface Props {
    currentPath?: string;
}

const { currentPath = '' } = Astro.props;

// ─── Sections statiques ──────────────────────────────────────────────────────

interface NavLink {
    href:        string;
    label:       string;
    ariaCurrent: 'page' | undefined;
}

const gettingStartedLinks: NavLink[] = [
    { href: '/getting-started/quickstart', label: 'Démarrage rapide', ariaCurrent: undefined },
    { href: '/getting-started/utilisation',  label: 'Utilisation',  ariaCurrent: undefined },
].map((link) => ({
    ...link,
    ariaCurrent: currentPath === link.href ? ('page' as const) : undefined,
}));

const foundationsLinks: NavLink[] = [
    { href: '/foundations/tokens', label: 'Design Tokens', ariaCurrent: undefined },
].map((link) => ({
    ...link,
    ariaCurrent: currentPath === link.href ? ('page' as const) : undefined,
}));

// ─── Composants (dynamique depuis CEM + MDX) ────────────────────────────────

interface NavChild {
    href:        string;
    label:       string;
    ariaCurrent: 'page' | undefined;
}

interface NavItem {
    href:        string;
    label:       string;
    ariaCurrent: 'page' | undefined;
    children:    NavChild[];
}

const allComponents: CemDeclaration[] = getCustomElements(manifest);

const allMdx   = await getCollection('components');
const mdxByTag = Object.fromEntries(allMdx.map((e) => [e.data.tagName, e]));

const childrenByParent = allComponents.reduce<Record<string, CemDeclaration[]>>(
    (acc, c) => {
        const parent = c['x-parent'];
        if (!parent) return acc;
        (acc[parent] ??= []).push(c);
        return acc;
    },
    {}
);

const componentItems: NavItem[] = allComponents
    .filter((c) => !c['x-parent'])
    .map((c) => {
        const href     = '/components/' + getSlug(c.tagName!);
        const rawChildren = childrenByParent[c.tagName!] ?? [];

        return {
            href,
            label:       mdxByTag[c.tagName!]?.data.title ?? c.name,
            ariaCurrent: currentPath === href ? ('page' as const) : undefined,
            children:    rawChildren.map((child) => {
                const childHref = '/components/' + getSlug(child.tagName!);
                return {
                    href:        childHref,
                    label:       mdxByTag[child.tagName!]?.data.title ?? child.name,
                    ariaCurrent: currentPath === childHref ? ('page' as const) : undefined,
                };
            }),
        };
    });
---

<nav aria-label="Design System">
    <div class="nav-container">
        <div class="nav-section">
            <h2>Bien démarrer</h2>
            <ul class="nav-list">
                {gettingStartedLinks.map((link) => (
                    <li>
                        <a href={link.href} aria-current={link.ariaCurrent}>{link.label}</a>
                    </li>
                ))}
            </ul>
        </div>

        <div class="nav-section">
            <h2>Fondations</h2>
            <ul class="nav-list">
                {foundationsLinks.map((link) => (
                    <li>
                        <a href={link.href} aria-current={link.ariaCurrent}>{link.label}</a>
                    </li>
                ))}
            </ul>
        </div>

        <div class="nav-section">
            <h2>Composants</h2>
            <ul class="nav-list">
                {componentItems.map((item) => (
                    <li class={item.children.length ? 'has-children' : ''}>
                        <a href={item.href} aria-current={item.ariaCurrent}>{item.label}</a>
                        {item.children.length > 0 && (
                            <ul class="nav-children">
                                {item.children.map((child) => (
                                    <li>
                                        <a href={child.href} aria-current={child.ariaCurrent}>
                                            {child.label}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        )}
                    </li>
                ))}
            </ul>
        </div>
    </div>
</nav>

<style>
    nav {
        display:         flex;
        flex-direction:  column;
        justify-content: space-between;
        flex-grow:       1;
        padding:         4rem 0.75rem 1.25rem;
        border-right:    1px solid var(--doc-nav-border, #e2e4e9);
        background:      var(--doc-nav-bg, #f8f9fb);
        position:        sticky;
        top:             0;
        height:          100%;
        overflow-y:      auto;
        scrollbar-width: thin;
        scrollbar-color: var(--doc-border, #d1d5db) transparent;
    }

    nav::-webkit-scrollbar       { width: 4px; }
    nav::-webkit-scrollbar-thumb { background: var(--doc-border, #d1d5db); border-radius: 4px; }

    /* ── Marque (masquée sur desktop, le header a déjà le logo) ── */

    .nav-brand {
        font-weight:     500;
        font-size:       .8rem;
        letter-spacing:  -0.02em;
        color:           var(--doc-text, #1a1d26);
        text-decoration: none;
        margin: 0;
        flex-shrink:     0;
    }

    .brand-accent {
        color: var(--ar-color-interactive, #2563eb);
    }

    /* ── Sections ────────────────────────────────────────────── */

    .nav-container {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .nav-section {
        margin-bottom: 1.25rem;
    }

    .nav-section h2 {
        font-size:      0.65rem;
        font-weight:    600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color:          #6b7280;
        padding:        0 0.75rem;
        margin:         0 0 0.4rem;
    }

    /* ── Listes ──────────────────────────────────────────────── */

    .nav-list,
    .nav-children {
        list-style: none;
        margin:     0;
        padding:    0;
    }

    .nav-list a {
        display:         block;
        padding:         0.4rem 0.75rem;
        color:           var(--doc-text-subtle, #4b5563);
        text-decoration: none;
        border-radius:   0.375rem;
        font-size:       0.85rem;
        font-weight:     450;
        transition:      background 0.12s, color 0.12s;
        border-left:     5px solid transparent;
    }

    .nav-list a:hover {
        background: var(--doc-nav-bg-hover, #f3efff);
        color:      var(--doc-text);
    }

    .nav-list a[aria-current="page"] {
        background:                var(--doc-accent-bg, #f3efff);
        color:                     var(--doc-accent, #7c3aed);
        border-top-left-radius:    0;
        border-bottom-left-radius: 0;
        border-left-color:         var(--doc-accent, #7c3aed);
    }

    /* ── Enfants (sous-composants) ───────────────────────────── */

    .nav-children {
        margin:       0.15rem 0 0.25rem 1.2rem;
        padding-left: 0;
        border-left:  1.5px solid var(--doc-border, #dfe1e7);
    }

    .nav-children a {
        font-size: 0.78rem;
        padding:   0.3rem 0.6rem;
        color:     var(--doc-text-subtle, #4b5563);
    }

    /* ── Footer nav (theme toggle dans le drawer mobile uniquement) ── */

