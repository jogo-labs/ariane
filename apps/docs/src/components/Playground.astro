---
/**
 * Playground.astro
 *
 * Affiche les variantes d'un composant empilées verticalement (style Webawesome),
 * un playground interactif avec contrôles générés depuis le CEM,
 * et la référence API complète via ComponentApi.
 *
 * Tout le rendu des composants est server-side (Fragment set:html).
 * La coloration syntaxique est assurée par highlight.js (client-side, uniforme).
 * Le JS client gère la copie du code, les contrôles du playground et le toggle preview.
 */

import ComponentApi from './ComponentApi.astro';
import { type CemDeclaration, type CemControl } from '../utils/cem-types.ts';

interface Variant {
    name:         string;
    label?:       string;
    description?: string;
    html:         string;
}

interface Props {
    variants:       Variant[];
    tagName:        string;
    displayMode:    'demo' | 'docs';
    parentTag?:     string;
    playgroundHtml: string;
    controls:       CemControl[];
    component:      CemDeclaration;
}

const {
    variants,
    tagName,
    displayMode = 'demo',
    parentTag,
    playgroundHtml,
    controls,
    component,
} = Astro.props;

const showPlayground = displayMode === 'demo';
---

{/* ── Exemples (variantes) ── */}
{variants.length > 0 && (
    <section id="exemples">
        <h4 class="section-title">Exemples</h4>
        <div class="main-section">
            {variants.map((variant) => (
                <section id={`exemple-${variant.name}`}>
                    <h5 class="subsection-title">{variant.label ?? variant.name}</h5>
                    {variant.description && (
                        <p class="variant-description">{variant.description}</p>
                    )}
                    <div>
                        <div class="preview-wrap">
                            <div class="preview">
                                <Fragment set:html={variant.html} />
                            </div>
                        </div>
                        <div class="code-block">
                            <button class="copy-btn" data-copy aria-label="Copier le code">Copier</button>
                            <pre><code class="language-html">{variant.html.trim()}</code></pre>
                        </div>
                    </div>
                </section>
            ))}
        </div>
    </section>
)}

{/* ── Encart parent pour les sous-composants ── */}
{parentTag && (
    <div class="parent-notice">
        {/* <span class="parent-notice-icon">&#8593;</span> */}
        Ce composant est un sous-composant de
        <a href={`/components/${parentTag.replace(/^ar-/, '')}`}>
            <code>&lt;{parentTag}&gt;</code>
        </a>
    </div>
)}

{/* ── Playground interactif ── */}
{showPlayground && (
    <section class="playground-section" id="playground" data-playground data-tag-name={tagName}>
        <h4 class="subsection-title">Playground</h4>
        <div class="playground-card">
            <div class="preview-wrap">
                <div class="preview" data-playground-preview>
                    <Fragment set:html={playgroundHtml} />
                </div>
            </div>
            <div class="playground-code-block">
                <button class="copy-btn" data-copy-playground aria-label="Copier le code">Copier</button>
                {/* Le <pre><code> est mis à jour par playground.js après chaque changement de contrôle */}
                <pre data-playground-pre><code class="language-html" data-playground-code>{playgroundHtml.trim()}</code></pre>
            </div>
            {controls.length > 0 && (
                <div class="controls-panel">
                    {controls.map((ctrl) => (
                        <label class="control-row">
                            <span class="control-label">{ctrl.attribute}</span>
                            {ctrl.controlType === 'select' && (
                                <select
                                    data-attr={ctrl.attribute}
                                    data-playground-ctrl
                                    data-default={ctrl.default ?? ''}
                                >
                                    {ctrl.addDefault && (
                                        <option value="">Par défaut</option>
                                    )}
                                    {ctrl.options.map((opt) => (
                                        <option value={opt}>{opt}</option>
                                    ))}
                                </select>
                            )}
                            {ctrl.controlType === 'checkbox' && (
                                <input
                                    type="checkbox"
                                    data-attr={ctrl.attribute}
                                    data-playground-ctrl
                                />
                            )}
                            {ctrl.controlType === 'text' && (
                                <input
                                    type="text"
                                    data-attr={ctrl.attribute}
                                    data-playground-ctrl
                                    data-default={ctrl.default ?? ''}
                                    placeholder={ctrl.default ?? ''}
                                />
                            )}
                            {ctrl.controlType === 'number' && (
                                <input
                                    type="number"
                                    data-attr={ctrl.attribute}
                                    data-playground-ctrl
                                    data-default={ctrl.default ?? ''}
                                    placeholder={ctrl.default ?? ''}
                                />
                            )}
                        </label>
                    ))}
                </div>
            )}
        </div>
    </section>
)}

{/* ── Référence API ── */}
<section id="reference-api">
    <h4 class="section-title">Référence API</h4>
    <ComponentApi component={component} />
</section>

<style>
    @import '../styles/doc-prose.css';

    /* ── Variantes ─────────────────────────────────────── */

    .examples-section {
        display:        flex;
        flex-direction: column;
        gap:            2.5rem;
    }

    .variant,
    .playground-section {
        display:        flex;
        flex-direction: column;
        gap:            1rem;
    }

    .playground-card {
        display:        flex;
        flex-direction: column;
    }

    h5 {
        font-size:   1rem;
        font-weight: 600;
        color:       var(--doc-text, #374151);
        margin:      0;
    }

    .variant-description {
        margin: .75rem 0;
    }

    /* ── Preview ─────────────────────────────────────── */

    .preview-wrap {
        position: relative;
    }

    .preview-theme-toggle {
        position:        absolute;
        top:             0.5rem;
        right:           0.5rem;
        z-index:         10;
        display:         flex;
        align-items:     center;
        justify-content: center;
        width:           1.75rem;
        height:          1.75rem;
        background:      color-mix(in srgb, var(--doc-bg, #ffffff) 75%, transparent);
        backdrop-filter: blur(4px);
        border:          1px solid var(--doc-border, #e5e7eb);
        border-radius:   0.375rem;
        cursor:          pointer;
        color:           var(--doc-text-muted, #6b7280);
        transition:      background 0.15s;
    }

    .preview-theme-toggle:hover {
        background: var(--doc-bg, #ffffff);
    }

    .preview {
        display:       flex;
        flex-wrap:     wrap;
        gap:           0.75rem;
        align-items:   center;
        padding:       2rem;
        border:        1px solid var(--doc-border, #e5e7eb);
        border-radius: 0.5rem 0.5rem 0 0;
    }

    .preview {
        background: var(--doc-bg);
    }

    /* ── Code block ─────────────────────────────────── */

    .code-block,
    .playground-code-block {
        position:   relative;
        border:     1px solid var(--doc-border, #e5e7eb);
        border-top: none;
        overflow:   hidden;
    }

    .code-block          { border-radius: 0 0 0.5rem 0.5rem; }
    .playground-code-block { border-radius: 0; }

    .copy-btn {
        position:      absolute;
        top:           0.5rem;
        right:         0.5rem;
        padding:       0.25rem 0.6rem;
        background:    color-mix(in srgb, var(--doc-nav-bg, #1f2937) 85%, transparent);
        color:         var(--doc-text-muted, #d1d5db);
        border:        none;
        border-radius: 0.25rem;
        font-size:     0.75rem;
        cursor:        pointer;
        transition:    background 0.15s;
        z-index:       1;
    }

    .copy-btn:hover  { background: var(--doc-nav-bg, #374151); }
    .copy-btn.copied { background: var(--ar-color-success-text, #0a8560); color: var(--ar-color-white, #fff); }

    /* highlight.js gère le background via son thème CSS — on aligne juste la typo */
    :global(.code-block pre),
    :global(.playground-code-block pre) {
        margin:      0;
        padding:     1rem 1.25rem;
        overflow-x:  auto;
        font-family: 'Fira Code', 'Cascadia Code', monospace;
        font-size:   0.8rem;
        line-height: 1.6;
        background:  var(--doc-code-block-bg, #1e1e2e);
    }

    :global(.code-block pre code),
    :global(.playground-code-block pre code) {
        font-family: inherit;
        font-size:   inherit;
        padding:     0;
        background:  transparent;
        color:       #cdd6f4;
    }

    :global(.code-block pre) {
        border-radius: 0 0 0.5rem 0.5rem;
    }

    /* ── Playground contrôles ────────────────────────── */

    .playground-section .preview-wrap { margin-bottom: 0; }
    .playground-section .preview {
        border-radius: 0.5rem 0.5rem 0 0;
        border-bottom: none;
    }

    .controls-panel {
        border:        1px solid var(--doc-border, #e5e7eb);
        border-top:    none;
        border-radius: 0 0 0.5rem 0.5rem;
        padding:       1rem 1.5rem;
        background:    var(--doc-nav-bg, #f9fafb);
        display:       flex;
        flex-wrap:     wrap;
        gap:           1rem 2rem;
        align-items:   start;
    }

    .control-row {
        display:        flex;
        flex-direction: column;
        gap:            0.25rem;
        min-width:      140px;
    }

    .control-label {
        font-size:   0.75rem;
        font-weight: 600;
        color:       var(--doc-text-muted, #6b7280);
        font-family: 'Fira Code', 'Cascadia Code', monospace;
    }

    .control-row select,
    .control-row input[type="text"],
    .control-row input[type="number"] {
        padding:       0.3rem 0.5rem;
        border:        1px solid var(--doc-border, #d1d5db);
        border-radius: 0.25rem;
        font-size:     0.875rem;
        background:    var(--doc-bg, #fff);
        color:         var(--doc-text, #111827);
        width:         100%;
    }

    .control-row input[type="checkbox"] {
        width:      1.1rem;
        height:     1.1rem;
        cursor:     pointer;
        margin-top: 0.2rem;
    }

    /* ── Encart parent ───────────────────────────────── */

    .parent-notice {
        display:       flex;
        align-items:   center;
        gap:           0.5rem;
        padding:       0.75rem 1rem;
        background:    color-mix(in srgb, var(--ar-color-interactive, #2563eb) 8%, transparent);
        border:        1px solid color-mix(in srgb, var(--ar-color-interactive, #2563eb) 20%, transparent);
        border-radius: 0.5rem;
        font-size:     0.875rem;
        color:         var(--doc-text, #374151);
        margin:        1rem 0;
    }

    .parent-notice-icon {
        font-size:   1.1rem;
        font-weight: 700;
        color:       var(--ar-color-interactive, #2563eb);
    }

    .parent-notice a {
        color:           var(--ar-color-interactive, #2563eb);
        text-decoration: none;
        font-weight:     600;
    }

    .parent-notice a:hover { text-decoration: underline; }
</style>
