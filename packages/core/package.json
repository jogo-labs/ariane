{
  "name": "@ariane-ui/core",
  "version": "0.1.0-alpha.4",
  "type": "module",
  "description": "Accessible web components library",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cdn": "./cdn/index.js",
    "./cdn/autoloader": "./cdn/autoloader.js",
    "./themes/*": "./dist/styles/themes/*.css",
    "./custom-elements.json": "./dist/custom-elements.json",
    "./dist/*": "./dist/*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "cdn"
  ],
  "scripts": {
    "build": "npm run build:manifest && npm run build:bundles && npm run build:css && npm run build:types",
    "build:manifest": "cem analyze --config cem.config.js",
    "build:bundles": "node scripts/build-bundles.js",
    "build:css": "node scripts/build-css.js",
    "build:types": "tsc --emitDeclarationOnly --declarationMap",
    "dev": "npm run build:manifest && node scripts/build-bundles.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "web-test-runner",
    "test:browser:watch": "web-test-runner --watch",
    "lint": "eslint src",
    "create": "node scripts/create-component.js"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.3",
    "@open-wc/testing": "^4.0.0",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^21.0.0",
    "@vitest/coverage-v8": "^3.0.4",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "custom-element-vs-code-integration": "^1.5.0",
    "esbuild": "^0.24.2",
    "happy-dom": "^15.11.7",
    "sinon": "^21.0.3",
    "vitest": "^3.0.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jogo-labs/ariane"
  },
  "customElements": "dist/custom-elements.json",
  "config": {
    "componentPrefix": "ar"
  }
}
